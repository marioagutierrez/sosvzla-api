# .gitignore
# Ignore system-specific and build-generated files.

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment Variables
.env
.env.local
.env.*.local

# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
build/
bin/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Go-specific ignores
cmd/cmd
cmd/main
sosvzla.lat
